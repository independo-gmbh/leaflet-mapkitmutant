{
  "name": "@independo/leaflet.mapkitmutant",
  "description": "Leaflet plugin to use Apple MapKit JS as a map provider",
  "version": "1.0.6-dev.1",
  "main": "dist/Leaflet.MapkitMutant.js",
  "types": "dist/Leaflet.MapkitMutant.d.ts",
  "unpkg": "dist/Leaflet.MapkitMutant.js",
  "type": "commonjs",
  "contributors": [
    {
      "name": "Iván Sánchez Ortega",
      "email": "ivan@sanchezortega.es"
    },
    {
      "name": "Independo GmbH",
      "email": "admin@independo.app"
    }
  ],
  "author": "Independo GmbH",
  "homepage": "https://github.com/independo-gmbh/leaflet-mapkitmutant#readme",
  "license": "LGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/independo-gmbh/leaflet-mapkitmutant.git"
  },
  "bugs": {
    "url": "https://github.com/independo-gmbh/leaflet-mapkitmutant/issues"
  },
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "format": "prettier \"{src,test}/**/*.ts\" --write",
    "format:check": "prettier \"{src,test}/**/*.ts\" --check",
    "lint": "eslint . && prettier \"{src,test}/**/*.ts\" --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup && cp src/Leaflet.MapkitMutant.d.ts dist/Leaflet.MapkitMutant.d.ts",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "map",
    "leaflet",
    "mapkit"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@saithodev/semantic-release-backmerge": "^4.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/leaflet": "^1.9.21",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "mapkit-typescript": "^5.18.2",
    "prettier": "^3.9.5",
    "semantic-release": "^25.0.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "leaflet": "^1.9.4"
  }
}
